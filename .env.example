# Скопируйте в `.env` в корне mimusicback-master — приложение подхватит его при `gradlew run`, если переменная не задана в системе.
# Либо экспортируйте в PowerShell: $env:DB_PASSWORD = "ваш_пароль_postgres"

# JDBC целиком (если задан — DB_HOST/DB_PORT/DB_NAME не нужны):
# DB_JDBC_URL=jdbc:postgresql://localhost:5432/music_app

DB_HOST=localhost
DB_PORT=5432
DB_NAME=music_app
DB_USER=postgres
DB_PASSWORD=1234
# DB_POOL_SIZE=10

MUSIC_STORAGE_DIR=music_storage
FILE_STORAGE_ROOT=file_storage

# Регистрация: true — без ключа беты регистрация запрещена (ключ в теле JSON inviteCode или в БД invite_keys).
# REQUIRE_INVITE_KEY=false
# BETA_INVITE_CODES=MIMUSIC-BETA-CLOSED-2026,MIMUSIC-BETA-DEV
# Тестовый ключ из БД (сидится при старте сервера): TESTK-EYDEV-BUILD
